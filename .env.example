# Configuración de Supabase (Tanda 6 — sincronización en la nube).
#
# Copiá este archivo como ".env" y completá con los datos de TU proyecto Supabase.
# El archivo ".env" real está en .gitignore y NUNCA se sube al repositorio.

# URL del proyecto (Supabase → Project Settings → Data API → Project URL).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública "publishable" / anon (Supabase → Project Settings → API Keys).
# Es pública por diseño: va del lado del cliente y queda protegida por las reglas
# Row Level Security (RLS). No es un secreto, pero igual no se versiona.
VITE_SUPABASE_KEY=sb_publishable_XXXXXXXXXXXXXXXX
